---
import { Image } from 'astro:assets';
import profile from '../assets/profile.png';
---

<div class="win me-win">
  <div class="win-hd">
    <div class="dots"><i></i><i></i><i></i></div>
    <span class="me-title">~/me · whoami.jpg</span>
    <span class="me-tag">file</span>
  </div>
  <div class="me-bd">
    <div class="me-photo">
      <Image src={profile} alt="Vasile Pop" widths={[120, 240]} sizes="120px" />
      <div class="me-tint"></div>
      <div class="me-scan"></div>
      <div class="me-rec">● REC</div>
    </div>
    <div class="me-meta">
      <div class="me-name">Vasile Pop</div>
      <div class="me-role">SDET · web dev · bass</div>
      <dl class="me-uid">
        <dt>uid</dt><dd>1000</dd>
        <dt>loc</dt><dd>cluj, ro</dd>
        <dt>exp</dt><dd>16y</dd>
      </dl>
    </div>
  </div>
</div>

<style>
  .win {
    border: 1px solid var(--term-line-strong);
    background: rgba(0, 0, 0, 0.5);
    border-radius: 4px;
    font-family: var(--term-mono);
    box-shadow: 0 0 24px rgba(var(--term-accent-rgb), 0.05);
  }
  .win-hd {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--term-line);
    font-size: 11px;
    color: var(--term-dim);
    letter-spacing: 0.04em;
  }
  .win-hd .dots {
    display: flex;
    gap: 5px;
  }
  .win-hd .dots i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #444;
    display: inline-block;
  }
  .win-hd .dots i:nth-child(1) {
    background: var(--term-error);
  }
  .win-hd .dots i:nth-child(2) {
    background: var(--term-warn);
  }
  .win-hd .dots i:nth-child(3) {
    background: var(--term-accent);
  }
  .me-title {
    flex: 1;
  }
  .me-tag {
    color: var(--term-accent);
  }
  .me-bd {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 14px;
    align-items: center;
    padding: 14px;
  }
  .me-photo {
    position: relative;
    width: 120px;
    height: 120px;
    border: 1px solid var(--term-line-strong);
    background: #0a0e10;
    overflow: hidden;
  }
  .me-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.55) contrast(1.05) brightness(0.95);
    mix-blend-mode: screen;
  }
  .me-tint {
    position: absolute;
    inset: 0;
    background: rgba(var(--term-accent-rgb), 0.18);
    mix-blend-mode: multiply;
    pointer-events: none;
  }
  .me-scan {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(180deg, transparent 0 2px, rgba(0, 0, 0, 0.3) 3px);
    pointer-events: none;
  }
  .me-rec {
    position: absolute;
    bottom: 4px;
    left: 6px;
    font-size: 9px;
    color: var(--term-accent);
    letter-spacing: 0.08em;
    text-shadow: 0 0 6px rgba(var(--term-accent-rgb), 0.6);
  }
  .me-meta {
    font-size: 12px;
    line-height: 1.55;
  }
  .me-name {
    color: var(--term-accent);
    font-family: var(--term-display);
    font-size: 18px;
    letter-spacing: -0.01em;
    margin-bottom: 2px;
  }
  .me-role {
    color: var(--term-dim);
    font-size: 11px;
    margin-bottom: 8px;
  }
  .me-uid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2px 10px;
    font-size: 11px;
    margin: 0;
  }
  .me-uid dt {
    color: var(--term-dim);
  }
  .me-uid dd {
    color: var(--term-fg);
    margin: 0;
  }
</style>
