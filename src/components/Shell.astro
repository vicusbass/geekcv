---
// Interactive terminal вҖ” command history, j/k recall, route nav, bass --play easter egg.
---

<div class="win shell">
  <div class="win-hd">
    <div class="dots"><i></i><i></i><i></i></div>
    <span class="shell-title">~/vicusbass вҖ” zsh</span>
    <span class="shell-clock" data-shell-clock>--:--:--</span>
  </div>
  <div class="shell-bd">
    <div class="shell-history" data-shell-history>
      <div class="shell-line shell-sys"><span class="shell-glyph">#</span><span>vicusbass.os v2.6.0 вҖ” type `help` for commands</span></div>
      <div class="shell-line shell-sys"><span class="shell-glyph">#</span><span>tip: try `bass --play`, `cv`, `projects`, `whoami`</span></div>
    </div>
    <pre class="shell-bass" data-shell-bass hidden></pre>
    <div class="shell-input-row">
      <span class="shell-glyph shell-prompt">$</span>
      <input
        type="text"
        class="shell-input"
        data-shell-input
        placeholder="type `help` and press enter"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
      />
    </div>
    <div class="shell-hint">
      <span>вҶ‘/вҶ“ history</span>
      <span>tab to cycle</span>
      <span>try: <em>bass --play</em></span>
    </div>
  </div>
</div>

<script>
  type LineKind = 'sys' | 'in' | 'out' | 'err';

  const MANIFESTO =
    'I build, test and break software for a living. I write Python and TypeScript, design end-to-end test strategies, and ship the occasional side project. Off the clock I play bass and raise two small humans.';

  const ROUTES: Record<string, string> = {
    projects: '/projects',
    work: '/projects',
    cv: '/cv',
    resume: '/cv',
    blog: '/blog',
    writing: '/blog',
    contact: '/contact',
    hire: '/contact',
    'hire vasile': '/contact',
    home: '/',
  };

  const BASS_FRAMES = [
    '  вҷӘ  в”Ҡв”Ҡв”ғв”Ҡв”Ҡв”ғв”Ҡв”Ҡ  в”Җв”Җв”Җв”Җ G в”Җв”Җв”Җв”Җ  ',
    '    вҷ¬в”Ҡв”Ҡв”ғв”Ҡв”Ҡв”ғв”Ҡв”Ҡв”Җв”Җв”Җв”Җ D в”Җв”Җв”Җв”Җ  ',
    '  вҷӘв”Ҡв”Ҡв”ғвҷ«в”Ҡв”ғв”Ҡв”Ҡ  в”Җв”Җв”Җв”Җ A в”ҖвҷӘв”Җв”Җ  ',
    '  в”Ҡв”Ҡв”ғв”Ҡвҷ¬в”ғв”Ҡв”Ҡ  в”Җв”Җв”Җв”Җ E в”Җв”Җв”Җв”Җв”Җв”Җ  ',
    '  в”ҠвҷӘв”ғв”Ҡв”Ҡв”ғвҷ«в”Ҡ  в”Җв”Җв”Җв”Җ G в”Җв”Җв”ҖвҷӘв”Җв”Җ  ',
    '  в”Ҡв”Ҡв”ғвҷӘв”Ҡв”ғв”Ҡвҷ¬  в”Җв”Җв”Җв”Җ D в”Җв”Җв”Җв”Җв”Җв”Җ  ',
    '  в”Ҡв”Ҡв”ғв”Ҡв”Ҡвҷ«в”Ҡв”Ҡ  в”Җв”Җв”Җв”Җ A в”Җв”Җвҷ¬в”Җв”Җв”Җ  ',
    '  вҷӘв”Ҡв”ғв”Ҡв”Ҡв”ғвҷӘв”Ҡ  в”Җв”Җ thump в”ҖвҷӘв”Җ  ',
  ];

  const root = document.querySelector<HTMLElement>('.shell');
  if (root) {
    const history = root.querySelector<HTMLDivElement>('[data-shell-history]')!;
    const input = root.querySelector<HTMLInputElement>('[data-shell-input]')!;
    const bassEl = root.querySelector<HTMLElement>('[data-shell-bass]')!;
    const clock = root.querySelector<HTMLElement>('[data-shell-clock]')!;
    const scrollHost = root.querySelector<HTMLElement>('.shell-bd')!;

    const tick = () => {
      clock.textContent = new Date().toLocaleTimeString('en-GB');
    };
    tick();
    setInterval(tick, 1000);

    const stack: string[] = [];
    let stackIdx = -1;
    let bassTimer: number | null = null;

    const GLYPH: Record<LineKind, string> = { in: '$', sys: '#', err: '!', out: ' ' };

    const push = (kind: LineKind, text: string) => {
      const row = document.createElement('div');
      row.className = `shell-line shell-${kind}`;
      const glyph = document.createElement('span');
      glyph.className = 'shell-glyph';
      glyph.textContent = GLYPH[kind];
      const body = document.createElement('span');
      body.textContent = text;
      row.append(glyph, body);
      history.appendChild(row);
      scrollHost.scrollTop = scrollHost.scrollHeight;
    };

    const playBass = () => {
      if (bassTimer) window.clearInterval(bassTimer);
      bassEl.hidden = false;
      bassEl.textContent = `вҷӘ bass --play  в–¶  4-string walking bass\n${BASS_FRAMES[0]}`;
      let i = 0;
      bassTimer = window.setInterval(() => {
        i++;
        if (i >= 32) {
          window.clearInterval(bassTimer!);
          bassTimer = null;
          bassEl.hidden = true;
          return;
        }
        bassEl.textContent = `вҷӘ bass --play  в–¶  4-string walking bass\n${BASS_FRAMES[i % BASS_FRAMES.length]}`;
      }, 180);
    };

    const run = (raw: string) => {
      const c = raw.trim();
      if (!c) return;
      stack.unshift(c);
      stackIdx = -1;
      push('in', c);
      const lower = c.toLowerCase();

      if (lower === 'help') {
        for (const line of [
          'available commands:',
          '  whoami            who is using this terminal',
          '  ls                list directory',
          '  cat about.txt     who I am, in prose',
          '  projects          go to /work',
          '  cv                go to /cv',
          '  blog              go to /blog',
          '  contact           go to /contact',
          '  bass --play       вҷӘ вҷ«',
          '  date              current date/time',
          '  clear             clear screen',
        ])
          push('out', line);
        return;
      }
      if (lower === 'whoami') return push('out', 'vasile В· sdet В· cluj-napoca В· open for consulting');
      if (lower === 'ls' || lower === 'ls -la') {
        for (const line of [
          'total 5',
          'drwxr-xr-x  vasile  staff   home/      вҶ’ /home',
          'drwxr-xr-x  vasile  staff   work/      вҶ’ /projects',
          'drwxr-xr-x  vasile  staff   cv/        вҶ’ /cv',
          'drwxr-xr-x  vasile  staff   blog/      вҶ’ /blog',
          'drwxr-xr-x  vasile  staff   contact/   вҶ’ /contact',
        ])
          push('out', line);
        return;
      }
      if (lower === 'cat about.txt' || lower === 'about') return push('out', MANIFESTO);
      if (lower in ROUTES) {
        push('out', `вҶ’ navigating to ${ROUTES[lower]}`);
        window.setTimeout(() => {
          window.location.href = ROUTES[lower];
        }, 250);
        return;
      }
      if (lower === 'bass --play' || lower === 'bass') {
        push('out', 'вҷӘ playing /home/vasile/loops/walking-bass.mid ...');
        playBass();
        return;
      }
      if (lower === 'date') return push('out', new Date().toString());
      if (lower === 'clear') {
        history.replaceChildren();
        return;
      }
      if (lower.startsWith('sudo'))
        return push('err', 'vasile is not in the sudoers file. this incident has been reported.');
      if (lower === 'exit' || lower === 'quit') return push('out', 'nice try. there is no exit.');
      push('err', `zsh: command not found: ${c}. try \`help\`.`);
    };

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        run(input.value);
        input.value = '';
      } else if (e.key === 'ArrowUp') {
        if (!stack.length) return;
        e.preventDefault();
        stackIdx = Math.min(stackIdx + 1, stack.length - 1);
        input.value = stack[stackIdx] ?? '';
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        stackIdx = Math.max(stackIdx - 1, -1);
        input.value = stackIdx < 0 ? '' : stack[stackIdx];
      }
    });

    // Click anywhere in the shell body to focus the input
    scrollHost.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).tagName !== 'INPUT') input.focus();
    });
  }
</script>

<style>
  .shell {
    border: 1px solid var(--term-line-strong);
    background: rgba(0, 0, 0, 0.5);
    border-radius: 4px;
    font-family: var(--term-mono);
    box-shadow: 0 0 24px rgba(var(--term-accent-rgb), 0.05);
  }
  .win-hd {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--term-line);
    font-size: 11px;
    color: var(--term-dim);
    letter-spacing: 0.04em;
  }
  .win-hd .dots {
    display: flex;
    gap: 5px;
  }
  .win-hd .dots i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #444;
    display: inline-block;
  }
  .win-hd .dots i:nth-child(1) {
    background: var(--term-error);
  }
  .win-hd .dots i:nth-child(2) {
    background: var(--term-warn);
  }
  .win-hd .dots i:nth-child(3) {
    background: var(--term-accent);
  }
  .shell-title {
    flex: 1;
  }
  .shell-clock {
    color: var(--term-accent);
    font-variant-numeric: tabular-nums;
  }

  .shell-bd {
    padding: 14px 16px;
    max-height: 480px;
    overflow: auto;
    font-size: 12.5px;
    cursor: text;
  }
  .shell-line {
    display: flex;
    gap: 8px;
    white-space: pre-wrap;
    word-break: break-word;
    color: var(--term-fg);
    line-height: 1.5;
  }
  .shell-line.shell-out {
    padding-left: 14px;
  }
  .shell-line.shell-sys {
    color: var(--term-dim);
  }
  .shell-line.shell-in .shell-glyph {
    color: var(--term-accent);
  }
  .shell-line.shell-sys .shell-glyph {
    color: var(--term-dim);
  }
  .shell-line.shell-err {
    color: var(--term-warn);
  }
  .shell-line.shell-err .shell-glyph {
    color: var(--term-warn);
  }
  .shell-glyph {
    display: inline-block;
    width: 1ch;
  }

  .shell-bass {
    margin: 10px 0 0;
    padding: 10px 12px;
    border: 1px solid var(--term-line-strong);
    border-radius: 3px;
    background: rgba(var(--term-accent-rgb), 0.06);
    color: var(--term-accent);
    font-size: 12px;
    white-space: pre;
    text-shadow: 0 0 8px rgba(var(--term-accent-rgb), 0.3);
  }

  .shell-input-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-top: 10px;
    border-top: 1px dashed var(--term-line);
    margin-top: 10px;
  }
  .shell-input-row .shell-glyph {
    color: var(--term-accent);
  }
  .shell-input {
    flex: 1;
    background: transparent;
    border: 0;
    color: var(--term-fg);
    font: inherit;
    outline: none;
    caret-color: var(--term-accent);
  }
  .shell-input::placeholder {
    color: var(--term-dim);
    opacity: 0.6;
  }

  .shell-hint {
    margin-top: 8px;
    font-size: 10.5px;
    color: var(--term-dim);
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .shell-hint em {
    font-style: normal;
    color: var(--term-accent);
  }
</style>
