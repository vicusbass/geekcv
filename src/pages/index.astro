    <h1 style="font-family:var(--term-display);font-size:36px;line-height:1.2;letter-spacing:-.01em;font-weight:500;color:var(--term-fg);margin:8px 0 0;max-width:30ch">
      I write tests that <em style="font-style:normal;color:var(--term-accent);background:rgba(var(--term-accent-rgb),.1);padding:0 6px;border-radius:3px;text-shadow:0 0 12px rgba(var(--term-accent-rgb),.4)">fail loudly</em><br/>
      and code that <em style="font-style:normal;color:var(--term-accent);background:rgba(var(--term-accent-rgb),.1);padding:0 6px;border-radius:3px;text-shadow:0 0 12px rgba(var(--term-accent-rgb),.4)">ships quietly</em>.
    </h1>

    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <a class="btn btn-prim" href="/projects">$ open ./work тЖТ</a>
      <a class="btn" href="/cv">$ cat cv.log</a>
      <a class="btn" href="/blog">$ ls /blog</a>
      <a class="btn" href="/contact">$ mail vasile</a>
    </div>
  </section>

  <section style="padding:0 24px">
    <div class="term-h" style="padding:48px 0 16px">
      <span class="lead">02 //</span>
      <h2>~/<em>latest</em></h2>
      <span class="right">selected ┬╖ last 24mo</span>
    </div>

    <div class="latest-grid">
      {latest.map((p, i) => (
        <a class="latest-card" href={p.data.url} target="_blank" rel="noreferrer">
          <div class="latest-card-hd">
            <span class="latest-id">./{p.id}</span>
            <span class="latest-yr">{p.data.year}</span>
          </div>
          {thumbs[i] && (
            <div class="latest-thumb" aria-hidden="true">
              <img src={thumbs[i]} alt="" loading="lazy" />
              <span class="latest-thumb-scan"></span>
            </div>
          )}
          <div class="latest-ttl">{p.data.title}</div>
          <div class="latest-card-ft">
            <span>{p.data.kind}</span>
            <span>тЖЧ</span>
          </div>
        </a>
      ))}
