---
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import Terminal from '../layouts/Terminal.astro';
import Me from '../components/Me.astro';
import Shell from '../components/Shell.astro';
import { getAsset } from '../lib/assets';
import { formatUptime } from '../lib/uptime';

const latest = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const thumbs = await Promise.all(
  latest.map(async (p) => {
    const src = getAsset(p.data.shot);
    if (!src) return null;
    const img = await getImage({
      src,
      width: 240,
      format: 'webp',
      quality: 80,
    });
    return img.src;
  }),
);

const stats: Array<[string, string]> = [
  ['HOST', 'cluj-napoca.ro · 46.77°N'],
  ['UPTIME', formatUptime()],
  ['LOCALE', 'en_US.UTF-8 / ro_RO'],
  ['SHELL', '/bin/vasile · zsh 5.9'],
  ['SDET', 'pytest · playwright · k6 · everything'],
  ['DEV', 'astro · next · ts · python'],
  ['STATUS', '● open for consulting'],
  ['SIDE', 'bass guitar · guitars'],
];

const SITE = Astro.site?.toString().replace(/\/$/, '') ?? 'https://vicusbass.com';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Vasile Pop',
    alternateName: 'vicusbass',
    url: SITE,
    jobTitle: 'SDET & Web Development Consultant',
    description:
      'Senior SDET and web development consultant with 21+ years of experience in test automation, end-to-end testing strategy, and shipping web applications.',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Cluj-Napoca',
      addressCountry: 'RO',
    },
    knowsAbout: [
      'Test Automation',
      'SDET',
      'Playwright',
      'pytest',
      'k6',
      'Cypress',
      'TypeScript',
      'Python',
      'React',
      'Next.js',
      'Astro',
      'CI/CD',
      'GitHub Actions',
      'QA Strategy',
      'End-to-end Testing',
    ],
    sameAs: [
      'https://github.com/vicusbass',
      'https://www.linkedin.com/in/vasilepop/',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'vicusbass',
    url: SITE,
    author: { '@type': 'Person', name: 'Vasile Pop' },
  },
];
---

<Terminal
  title="Vasile Pop — SDET & Web Development Consultant · Cluj-Napoca"
  description="Vasile Pop (vicusbass) — SDET and web development consultant in Cluj-Napoca. 21+ years building test automation, end-to-end testing strategy, Playwright, pytest, k6. Available for consulting."
  active="home"
  jsonLd={jsonLd}
>
  <section class="home-hero">
    <div class="home-left">
      <pre class="home-ascii">{`██╗   ██╗██╗ ██████╗██╗   ██╗███████╗██████╗  █████╗ ███████╗███████╗
██║   ██║██║██╔════╝██║   ██║██╔════╝██╔══██╗██╔══██╗██╔════╝██╔════╝
██║   ██║██║██║     ██║   ██║███████╗██████╔╝███████║███████╗███████╗
╚██╗ ██╔╝██║██║     ██║   ██║╚════██║██╔══██╗██╔══██║╚════██║╚════██║
 ╚████╔╝ ██║╚██████╗╚██████╔╝███████║██████╔╝██║  ██║███████║███████║
  ╚═══╝  ╚═╝ ╚═════╝ ╚═════╝ ╚══════╝╚═════╝ ╚═╝  ╚═╝╚══════╝╚══════╝`}</pre>

      <div class="home-build">
        <span>v2.6.0</span><span>·</span><span>build 2026.04</span><span>·</span>
        <span class="home-online">● online</span>
      </div>

      <h1 class="home-h1">
        SDET &amp; web dev consultant.<br />
        Tests that <em>fail loudly</em>,<br />
        code that <em>ships quietly</em>.
      </h1>
      <p class="home-lead">
        I'm <strong>Vasile Pop</strong> — 21+ years of test automation and web development out of Cluj-Napoca, working remote.
        I design end-to-end test strategies, build automation in <strong>Python &amp; TypeScript</strong>
        (Playwright, pytest, k6.io, cypress, anything), and ship production web apps in Astro and Next.js. Available for consulting,
        framework setup, technical interviews, and tricky QA audits.
      </p>

      <div class="home-cta">
        <a class="btn btn-prim" href="/projects">$ open ./work →</a>
        <a class="btn" href="/cv">$ cat cv.log</a>
        <a class="btn" href="/blog">$ ls /blog</a>
        <a class="btn" href="/contact">$ mail vasile</a>
      </div>

      <div class="home-stats">
        {stats.map(([k, v]) => (
          <div class="home-stats-row">
            <span class="home-stats-k">[{k}]</span>
            <span class="home-stats-v" data-uptime={k === 'UPTIME' ? '' : undefined}>{v}</span>
          </div>
        ))}
      </div>
    </div>

    <aside class="home-right">
      <Me />
      <Shell />
    </aside>
  </section>

  <section class="home-latest-wrap">
    <div class="term-h home-latest-h">
      <span class="lead">02 //</span>
      <h2>~/<em>latest</em></h2>
      <span class="right">selected · last 24mo</span>
    </div>

    <div class="latest-grid">
      {latest.map((p, i) => (
        <a class="latest-card" href={p.data.url} target="_blank" rel="noreferrer">
          <div class="latest-card-hd">
            <span class="latest-id">./{p.id}</span>
            <span class="latest-yr">{p.data.year}</span>
          </div>
          {thumbs[i] && (
            <div class="latest-thumb" aria-hidden="true">
              <img src={thumbs[i]} alt="" loading="lazy" />
              <span class="latest-thumb-scan"></span>
            </div>
          )}
          <div class="latest-ttl">{p.data.title}</div>
          <div class="latest-card-ft">
            <span>{p.data.kind}</span>
            <span>↗</span>
          </div>
        </a>
      ))}
    </div>

    <div class="home-latest-foot">
      <a class="btn" href="/projects">$ ls /work →</a>
    </div>
  </section>
</Terminal>

<style>
  .home-hero {
    padding: 48px 24px 24px;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 32px;
    align-items: start;
  }
  .home-left {
    min-width: 0;
  }
  .home-ascii {
    color: var(--term-accent);
    text-shadow: 0 0 12px rgba(var(--term-accent-rgb), 0.4);
    font-size: clamp(7px, 1.55vw + 1px, 10.5px);
    line-height: 1.1;
    margin: 0;
    font-weight: 500;
    overflow: hidden;
  }
  .home-build {
    margin-top: 16px;
    font-size: 11px;
    color: var(--term-dim);
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .home-online {
    color: var(--term-accent);
  }
  .home-h1 {
    font-family: var(--term-display);
    font-size: 36px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    font-weight: 500;
    color: var(--term-fg);
    margin: 28px 0 12px;
    max-width: 22ch;
  }
  .home-h1 em {
    font-style: normal;
    color: var(--term-accent);
    background: rgba(var(--term-accent-rgb), 0.1);
    padding: 0 6px;
    border-radius: 3px;
    text-shadow: 0 0 12px rgba(var(--term-accent-rgb), 0.4);
  }
  .home-lead {
    max-width: 56ch;
    color: var(--term-dim);
    font-size: 14px;
    line-height: 1.6;
    margin: 12px 0 24px;
  }
  .home-cta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .home-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    row-gap: 6px;
    column-gap: 24px;
    font-size: 12.5px;
    color: var(--term-dim);
    border-top: 1px dashed var(--term-line);
    padding-top: 16px;
    margin: 0;
  }
  .home-stats-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 10px;
  }
  .home-stats-k {
    color: var(--term-accent);
  }
  .home-stats-v {
    color: var(--term-fg);
  }

  .home-right {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .home-latest-wrap {
    padding: 0 24px;
  }
  .home-latest-h {
    padding: 48px 0 16px;
  }
  .home-latest-foot {
    margin-top: 16px;
    text-align: right;
  }

  .latest-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--term-line);
    border: 1px solid var(--term-line);
    margin-top: 16px;
  }
  .latest-card {
    background: var(--term-bg);
    padding: 20px 18px;
    text-decoration: none;
    color: var(--term-fg);
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 180px;
    position: relative;
    transition: background 0.15s;
  }
  .latest-card:hover {
    background: rgba(var(--term-accent-rgb), 0.06);
  }
  .latest-card-hd {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--term-dim);
  }
  .latest-id {
    color: var(--term-accent);
  }
  .latest-yr {
    font-variant-numeric: tabular-nums;
  }
  .latest-thumb {
    position: relative;
    width: 100%;
    height: 96px;
    overflow: hidden;
    border: 1px solid var(--term-line);
    background: #0a0e10;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
  }
  .latest-thumb img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    display: block;
    filter: saturate(0.75) contrast(1.05) brightness(0.95);
  }
  .latest-thumb-scan {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(180deg, transparent 0 2px, rgba(0, 0, 0, 0.25) 3px);
    mix-blend-mode: multiply;
    opacity: 0.5;
  }
  .latest-card:hover .latest-thumb {
    border-color: var(--term-line-strong);
    box-shadow: 0 0 12px rgba(var(--term-accent-rgb), 0.18);
  }
  .latest-card:hover .latest-thumb img {
    filter: saturate(0.9) contrast(1.1) brightness(1);
  }
  .latest-ttl {
    font-family: var(--term-display);
    font-size: 22px;
    letter-spacing: -0.01em;
    margin-top: auto;
    color: var(--term-fg);
  }
  .latest-card:hover .latest-ttl {
    color: var(--term-accent);
    text-shadow: 0 0 8px rgba(var(--term-accent-rgb), 0.3);
  }
  .latest-card-ft {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--term-dim);
  }

  @media (max-width: 1100px) {
    .home-hero {
      grid-template-columns: 1fr;
    }
    .home-right {
      position: static;
    }
  }
  @media (max-width: 900px) {
    .latest-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .latest-grid {
      grid-template-columns: 1fr;
    }
    .home-h1 {
      font-size: 28px;
    }
  }
</style>
