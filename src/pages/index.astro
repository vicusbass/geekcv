    <div style="margin-top:16px;text-align:right">
      <a class="btn" href="/projects">$ ls /work тЖТ</a>
    </div>
  </section>
</Terminal>

<style>
  .latest-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--term-line);
    border: 1px solid var(--term-line);
    margin-top: 16px;
  }
  .latest-card {
    background: var(--term-bg);
    padding: 20px 18px;
    text-decoration: none;
    color: var(--term-fg);
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 180px;
    position: relative;
    transition: background 0.15s;
  }
  .latest-card:hover {
    background: rgba(var(--term-accent-rgb), 0.06);
  }
  .latest-thumb {
    position: relative;
    width: 100%;
    height: 96px;
    overflow: hidden;
    border: 1px solid var(--term-line);
    background: #0a0e10;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
  }
  .latest-thumb img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    display: block;
    filter: saturate(0.75) contrast(1.05) brightness(0.95);
  }
  .latest-thumb-scan {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(180deg, transparent 0 2px, rgba(0, 0, 0, 0.25) 3px);
    mix-blend-mode: multiply;
    opacity: 0.5;
  }
  .latest-card:hover .latest-thumb {
    border-color: var(--term-line-strong);
    box-shadow: 0 0 12px rgba(var(--term-accent-rgb), 0.18);
  }
  .latest-card:hover .latest-thumb img {
    filter: saturate(0.9) contrast(1.1) brightness(1);
  }
  .latest-card-hd {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--term-dim);
  }
  .latest-id {
    color: var(--term-accent);
  }
  .latest-yr {
    font-variant-numeric: tabular-nums;
  }
  .latest-ttl {
    font-family: var(--term-display);
    font-size: 22px;
    letter-spacing: -0.01em;
    margin-top: auto;
    color: var(--term-fg);
  }
  .latest-card:hover .latest-ttl {
    color: var(--term-accent);
    text-shadow: 0 0 8px rgba(var(--term-accent-rgb), 0.3);
  }
  .latest-card-ft {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--term-dim);
  }
  @media (max-width: 900px) {
    .latest-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .latest-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
