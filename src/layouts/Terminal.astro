---
import '../styles/global.css';
import CRTLayers from '../components/CRTLayers.astro';
import TermTop from '../components/TermTop.astro';
import TermFoot from '../components/TermFoot.astro';

interface Props {
  title: string;
  active?: 'home' | 'work' | 'cv' | 'blog' | 'contact';
}

const { title, active } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Space+Mono:wght@400;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
    />
  </head>
  <body>
    <CRTLayers />
    <TermTop active={active} />
    <main class="term-stage page-enter">
      <slot />
    </main>
    <TermFoot />
  </body>
</html>
